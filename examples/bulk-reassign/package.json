{
  "name": "bulk-reassign",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @bulk-reassign/api --filter @bulk-reassign/web dev",
    "dev:api": "pnpm --filter @bulk-reassign/api dev",
    "dev:web": "pnpm --filter @bulk-reassign/web dev",
    "dev:next": "pnpm --parallel --filter @bulk-reassign/api --filter @bulk-reassign/web-next dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test",
    "test:e2e:vite": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test --project=vite",
    "test:e2e:next": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright test --project=next",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers playwright install chromium",
    "build": "pnpm -r --if-present build"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
